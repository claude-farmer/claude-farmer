{
  "name": "claude-farmer-vscode",
  "displayName": "Claude Farmer",
  "description": "🌱 Your code grows a farm. An idle pixel-art farming game in your sidebar.",
  "version": "0.3.1",
  "publisher": "doribear",
  "license": "MIT",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/claude-farmer/claude-farmer"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other", "Visualization"],
  "keywords": ["claude", "farming", "pixel-art", "idle-game", "fun"],
  "activationEvents": ["onStartupFinished"],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "claude-farmer",
          "title": "Claude Farmer",
          "icon": "media/farm-icon.svg"
        }
      ]
    },
    "views": {
      "claude-farmer": [
        {
          "type": "webview",
          "id": "claudeFarmer.farmView",
          "name": "🌱 My Farm"
        }
      ]
    },
    "commands": [
      {
        "command": "claudeFarmer.openFarm",
        "title": "Claude Farmer: Open Farm"
      },
      {
        "command": "claudeFarmer.openWeb",
        "title": "Claude Farmer: Open in Browser"
      },
      {
        "command": "claudeFarmer.login",
        "title": "Claude Farmer: Login with GitHub"
      }
    ],
    "configuration": {
      "title": "Claude Farmer",
      "properties": {
        "claudeFarmer.language": {
          "type": "string",
          "default": "auto",
          "enum": ["auto", "en", "ko"],
          "enumDescriptions": [
            "Auto-detect from VS Code language setting",
            "English",
            "한국어 (Korean)"
          ],
          "description": "Display language for Claude Farmer. 'auto' detects from VS Code settings."
        }
      }
    }
  },
  "scripts": {
    "build": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node",
    "dev": "npm run build -- --watch",
    "clean": "rm -rf dist",
    "package": "vsce package"
  },
  "devDependencies": {
    "@claude-farmer/shared": "*",
    "@types/vscode": "^1.85.0",
    "@types/node": "^22.0.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.25.0",
    "typescript": "^5.7.0"
  }
}
