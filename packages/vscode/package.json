{
  "name": "claude-farmer-vscode",
  "displayName": "Claude Farmer",
  "description": "🌱 Your code grows a farm. An idle pixel-art farming game in your sidebar.",
  "version": "0.1.0",
  "publisher": "claude-farmer",
  "license": "MIT",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/claude-farmer/claude-farmer"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other", "Visualization"],
  "keywords": ["claude", "farming", "pixel-art", "idle-game", "fun"],
  "activationEvents": ["onStartupFinished"],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "claude-farmer",
          "title": "Claude Farmer",
          "icon": "media/farm-icon.svg"
        }
      ]
    },
    "views": {
      "claude-farmer": [
        {
          "type": "webview",
          "id": "claudeFarmer.farmView",
          "name": "🌱 내 농장"
        }
      ]
    },
    "commands": [
      {
        "command": "claudeFarmer.openFarm",
        "title": "Claude Farmer: 내 농장 열기"
      },
      {
        "command": "claudeFarmer.openWeb",
        "title": "Claude Farmer: 웹에서 열기"
      }
    ]
  },
  "scripts": {
    "build": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node",
    "dev": "npm run build -- --watch",
    "clean": "rm -rf dist",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^22.0.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.25.0",
    "typescript": "^5.7.0"
  }
}
